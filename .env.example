# Copy to .env and fill BETTER_AUTH_SECRET (any 32+ char random string).

# Postgres (matches infra/docker-compose.dev.yml)
DATABASE_URL=postgresql://northbeam:northbeam@localhost:5432/northbeam

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-string-min-32-chars
BETTER_AUTH_URL=http://localhost:8000
PUBLIC_WEB_URL=http://localhost:3000

# Web → API (client). Defaults to :8000 if unset.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Email (optional) — magic links print to the API console when RESEND_API_KEY is unset.
# RESEND_API_KEY=
# RESEND_FROM=Northbeam <no-reply@northbeam.app>

# GitHub social sign-in (optional) — both required to enable.
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=
