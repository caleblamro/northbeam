{
  "name": "northbeam",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "./infra/dev.sh",
    "dev:down": "docker compose -f infra/docker-compose.dev.yml down",
    "dev:worker": "pnpm --filter @northbeam/api run dev:worker",
    "build": "turbo run build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @northbeam/db run generate",
    "db:migrate": "pnpm --filter @northbeam/db run migrate",
    "db:studio": "pnpm --filter @northbeam/db run studio",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "dotenv-cli": "11.0.0",
    "turbo": "2.9.14",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sharp"],
    "overrides": {
      "esbuild": ">=0.25.0",
      "postcss": ">=8.5.10"
    }
  }
}
