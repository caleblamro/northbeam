{
  "extends": "../../tsconfig.base.json",
  // `tsc --noEmit` covers src + tests; build emit goes through tsup. Including
  // tests catches type regressions in test stubs at `pnpm typecheck`.
  "compilerOptions": {
    "outDir": "dist",
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": ["src/**/*", "tests/**/*"]
}
