{
  "name": "@northbeam/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    "./trpc": "./src/trpc/index.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env.local --env-file-if-exists=.env.local src/index.ts",
    "build": "tsup",
    "start": "node --env-file-if-exists=../../.env.local --env-file-if-exists=.env.local dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@hono/node-server": "1.19.14",
    "@hono/trpc-server": "0.4.2",
    "@northbeam/config": "workspace:*",
    "@northbeam/core": "workspace:*",
    "@northbeam/db": "workspace:*",
    "@trpc/server": "11.17.0",
    "better-auth": "1.6.11",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.22",
    "resend": "4.0.1",
    "superjson": "2.2.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "tsup": "8.3.5",
    "tsx": "4.20.6"
  }
}
