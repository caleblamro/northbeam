{
  "name": "@northbeam/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    "./trpc": "./src/trpc/index.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env.local --env-file-if-exists=.env.local src/index.ts",
    "dev:worker": "tsx watch --env-file-if-exists=../../.env.local --env-file-if-exists=.env.local src/workers/index.ts",
    "build": "tsup",
    "start": "node --env-file-if-exists=../../.env.local --env-file-if-exists=.env.local dist/index.js",
    "start:worker": "node --env-file-if-exists=../../.env.local --env-file-if-exists=.env.local dist/workers/index.js",
    "seed:roles": "tsx --env-file-if-exists=../../.env.local --env-file-if-exists=.env.local scripts/seed-roles.ts",
    "sf:dev-connect": "tsx --env-file-if-exists=../../.env.local --env-file-if-exists=.env.local scripts/sf-dev-connect.ts",
    "sf:dry-run-map": "tsx scripts/sf-dry-run-map.ts",
    "sf:dry-run-report": "tsx scripts/sf-dry-run-report.ts",
    "sf:dry-run-flow": "tsx scripts/sf-dry-run-flow.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@hono/node-server": "1.19.14",
    "@hono/trpc-server": "0.4.2",
    "@northbeam/config": "workspace:*",
    "@northbeam/core": "workspace:*",
    "@northbeam/db": "workspace:*",
    "@northbeam/salesforce": "workspace:*",
    "@trpc/server": "11.17.0",
    "ai": "^6.0.206",
    "better-auth": "1.6.11",
    "bullmq": "5.34.10",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.22",
    "ioredis": "5.4.1",
    "resend": "4.0.1",
    "superjson": "2.2.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "tsup": "8.3.5",
    "tsx": "4.20.6",
    "vitest": "2.1.9"
  }
}
