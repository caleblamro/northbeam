{
  "name": "@northbeam/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./roles": "./src/roles.ts",
    "./field-types": "./src/field-types.ts",
    "./field-config-schemas": "./src/field-config-schemas.ts",
    "./formula": "./src/formula/index.ts",
    "./keys": "./src/keys.ts",
    "./views": "./src/views.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "push": "dotenv -e ../../.env.local -- drizzle-kit push",
    "generate": "dotenv -e ../../.env.local -- drizzle-kit generate",
    "migrate": "dotenv -e ../../.env.local -- drizzle-kit migrate",
    "studio": "dotenv -e ../../.env.local -- drizzle-kit studio --port 14304",
    "seed:org": "dotenv -e ../../.env.local -- tsx ./src/scripts/seed-org.ts",
    "setup:rls": "dotenv -e ../../.env.local -- tsx ./src/scripts/setup-app-role.ts",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "pino": "9.14.0",
    "postgres": "3.4.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "drizzle-kit": "0.31.10",
    "tsx": "4.20.6",
    "vitest": "2.1.9"
  }
}
